configuration {
    font: "JetBrains Mono 12";
}

window {

    background-color: @bg;
    border: 2px;
    border-color: @accent;
    border-radius: 8px;
    width: 400px;
    padding: 20px;
    location: center;
    anchor: center;
    border-radius: 15px;
    background-color: #1e1e2e;
    padding: 10px;

}

listview {
    lines: 2;
    spacing: 3px;
}

element {
    padding: 10px;
    border-radius: 8px;
    border: 1px;
    text-color: #503850;
    background-color: #503850;
}

element selected {
    background-color: #ffb6c1;
    text-color: #1e1e2e;
    border: 1px;

}