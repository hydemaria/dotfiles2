{
    "layer": "top",
    "position": "top",
    "margin-top": 10,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 4,

    "modules-left": ["custom/logo", "hyprland/workspaces"],
    "modules-center": ["custom/music"],
    "modules-right": ["cpu", "disk", "memory", "pulseaudio", "hyprland/language", "clock"],

    "custom/logo": {
        "format": "󰣇",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "format": "{name}"
    },

    "custom/music": {
        "format": "[ 󰝚 {} ]",
        "escape": true,
        "exec": "playerctl --player=spotify metadata --format '{{ title }} - {{ artist }}' | cut -c1-30",
        "interval": 5,
        "tooltip": false
    },

    "cpu": {
        "format": "󰻠 {usage}%",
        "tooltip": true,
        "tooltip-format": "Uso do Processador: {usage}%"
    },
    
    "disk": {
        "format": "󰋊 {percentage_used}%",
        "path": "/",
        "tooltip": false
    },
    
    "memory": {
        "format": "󰍛 {percentage}%",
        "tooltip": true,
        "tooltip-format": "Memória: {percentage}%"
    },

   "pulseaudio": {
        "format": "󰕾 {volume}%",
        "tooltip": true,
        "tooltip-format": "Volume: {volume}%"
    }

    "hyprland/language": {
        "format": "󰌌 {short}",
        "tooltip": false
    },

    "clock": {
        "format": "󰃭 {:%d/%m %H:%M}",
        "tooltip": false
    }
}