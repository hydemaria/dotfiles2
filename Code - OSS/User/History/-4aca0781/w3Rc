{
    "layer": "top",
    "position": "top",
    "margin-top": 10,
    "margin-left": 20,
    "margin-right": 20,
    "spacing": 4,

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["disk", "battery", "volume", "clock"],

    "clock": {
        "format": "󰃭 {:%d/%m %H:%M}",
        "tooltip": false
    },

    "disk": {
        "interval": 30,
        "format": "󰋊 {percentage_used}%",
        "path": "/",
        "tooltip": false
    },

    "battery": {
        "format": "󰁹 {capacity}%",
        "tooltip": false
    },

    "volume": {
        "format": "󰕾 {volume}%",
        "tooltip": false
    }
}